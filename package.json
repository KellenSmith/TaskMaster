{
    "name": "task-master",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "next dev --turbopack --experimental-https",
        "backup:db": "bash scripts/backup-db.sh",
        "backup:db:if-production": "if [ \"${VERCEL:-}\" = \"1\" ] && [ \"${VERCEL_ENV:-}\" = \"production\" ]; then pnpm backup:db; else echo 'Skipping DB backup (not a production Vercel deploy).'; fi",
        "build": "pnpm prisma-generate && pnpm prisma migrate deploy && next build",
        "analyze": "powershell -Command \"$env:ANALYZE='true'; next build\"",
        "start": "next start",
        "lint": "eslint .",
        "prisma-generate": "prisma generate",
        "prisma-migrate": "pnpm prisma migrate dev",
        "prisma-migrate-reset": "pnpm prisma migrate reset",
        "prisma-push": "pnpm prisma db push",
        "prisma-seed": "tsx prisma/seed.ts",
        "prisma-seed-users": "tsx prisma/seed-users.ts",
        "email": "email dev --dir=./src/app/lib/mail-service/mail-templates --port=3001",
        "test": "vitest",
        "test:ui": "vitest --ui",
        "test:coverage": "vitest run --coverage",
        "test:watch": "vitest watch",
        "format": "prettier --write .",
        "format:check": "prettier --check ."
    },
